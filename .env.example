# LLM Provider Configuration
# =========================

# Provider to use: openai, anthropic, deepseek, openrouter, local, zai, glm
LLM_PROVIDER=openai

# Model name (defaults to provider's default model)
LLM_MODEL=gpt-4o-mini

# Display name for observability (optional, for router/proxy servers)
# Use when model name is a router alias like "llm" but you want to see actual model name
# LLM_MODEL_DISPLAY_NAME=Qwen-2.5-7B

# Base URL (optional, for custom providers or local servers)
# LLM_BASE_URL=http://localhost:8000/v1

# Generic API key (overrides provider-specific key)
# LLM_API_KEY=sk-xxx


# Provider-Specific API Keys
# ==========================

# OpenAI
OPENAI_API_KEY=sk-xxx

# Anthropic (requires OpenAI-compatible proxy)
ANTHROPIC_API_KEY=sk-ant-xxx

# DeepSeek
DEEPSEEK_API_KEY=sk-xxx

# OpenRouter (multi-model gateway)
OPENROUTER_API_KEY=sk-or-xxx

# ZAI/GLM
ZAI_API_KEY=xxx

# Local server (llama.cpp, vLLM, etc.)
LOCAL_API_KEY=local


# llama.cpp Docker Configuration
# ==============================
# Model paths for docker-compose (mounted to container)
LLM_MODEL_PATH=/path/to/your/llm-model.gguf
EMBED_MODEL_PATH=/path/to/your/embedding-model.gguf
LLAMA_PORT=8001


# MCP Scraper Configuration
# ========================

# MCP Server Configuration (Tailscale)
MCP_HOST=100.85.22.99
MCP_PORT=8000


# Langfuse Observability Configuration
# =====================================
# Docs: https://langfuse.com/docs/observability/sdk/overview
# Start: make up
#
# Headless mode: Auto-creates org, project, and API keys on first run.
# No login needed - just use the generated keys below.

# Langfuse server URL
LANGFUSE_BASE_URL=http://localhost:3000

# API keys (auto-generated by make up, no login needed)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# UI login (optional, only if you want to view traces in browser)
# LANGFUSE_INIT_USER_EMAIL=admin@localhost
# LANGFUSE_INIT_USER_PASSWORD=admin


# Docker Internal Secrets (auto-generated)
# ========================================
# These are used by Docker services internally.

LANGFUSE_NEXTAUTH_SECRET=<auto-generated>
LANGFUSE_SALT=<auto-generated>
LANGFUSE_ENCRYPTION_KEY=<auto-generated>
LANGFUSE_DATABASE_URL=postgresql://langfuse:langfuse@postgres:5432/langfuse
LANGFUSE_POSTGRES_PASSWORD=langfuse
LANGFUSE_CLICKHOUSE_PASSWORD=clickhouse
LANGFUSE_REDIS_AUTH=redissecret
LANGFUSE_MINIO_ROOT_USER=minio
LANGFUSE_MINIO_ROOT_PASSWORD=miniosecret
