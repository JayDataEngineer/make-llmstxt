# LLM Provider Configuration
# =========================

# Provider to use: openai, anthropic, deepseek, openrouter, local, zai, glm
LLM_PROVIDER=openai

# Model name (defaults to provider's default model)
LLM_MODEL=gpt-4o-mini

# Base URL (optional, for custom providers or local servers)
# LLM_BASE_URL=http://localhost:8000/v1

# Generic API key (overrides provider-specific key)
# LLM_API_KEY=sk-xxx


# Provider-Specific API Keys
# ==========================

# OpenAI
OPENAI_API_KEY=sk-xxx

# Anthropic (requires OpenAI-compatible proxy)
ANTHROPIC_API_KEY=sk-ant-xxx

# DeepSeek
DEEPSEEK_API_KEY=sk-xxx

# OpenRouter (multi-model gateway)
OPENROUTER_API_KEY=sk-or-xxx

# ZAI/GLM
ZAI_API_KEY=xxx

# Local server (llama.cpp, vLLM, etc.)
LOCAL_API_KEY=local


# Scraper Backend Configuration
# ============================

# Scraper backend: "mcp" (default) or "firecrawl"
SCRAPER_BACKEND=mcp

# MCP Server Configuration (Tailscale)
# Default is your Tailscale IP
MCP_HOST=100.85.22.99
MCP_PORT=8000

# Firecrawl Configuration (alternative backend)
FIRECRAWL_API_KEY=fc-xxx
